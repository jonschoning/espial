    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dompurify": "^3.1.6",
    "ky": "^2.0.1",
    "marked": "^18.0.2",
    "moment": "^2.30.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.8"
  }
}
